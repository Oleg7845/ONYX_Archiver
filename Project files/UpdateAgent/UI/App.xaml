<Application x:Class="UpdateAgent.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:UpdateAgent.UI">
    <Application.Resources>
        <SolidColorBrush x:Key="MainTextBrush" Color="#808695" />
        <SolidColorBrush x:Key="MainTextLightBrush" Color="#E1E4FF" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#808695" Opacity="0.4" />
        <SolidColorBrush x:Key="GrayBrush" Color="#282828" />
        <SolidColorBrush x:Key="BlackBrush" Color="#1C1C1C" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#202020" />
        <SolidColorBrush x:Key="GreenButtonBrush" Color="#117863" />
        <SolidColorBrush x:Key="ErrorMessageBrush" Color="#B84444" />
    </Application.Resources>
</Application>
