<Window x:Class="OnyxArchiver.UI.MVVM.Archive.Add.Dialogs.ArchiveConfiguration.ArchiveConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OnyxArchiver.UI.MVVM.Archive.Add.Dialogs.ArchiveConfiguration"
        xmlns:components="clr-namespace:OnyxArchiver.UI.Components"
        mc:Ignorable="d"
        Title="ArchiveConfigurationWindow"
        Height="450"
        Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BlackBrush}">

    <StackPanel
        HorizontalAlignment="Center"
        Margin="0, 20">
        
        <TextBlock
            Text="Authentication"
            Foreground="{StaticResource MainTextBrush}"
            FontSize="20"
            FontWeight="Medium"
            Margin="0,0,0,25"
            HorizontalAlignment="Center"/>

        <components:TextInput
            Width="400"
            Height="40"
            Margin="0,0,0,15"
            Placeholder="Archive name"
            LeftIcon="/ONYX Archiver;component/UI/Resources/Icons/AuthForms/edit.png"
            Text="{Binding ArchiveName, UpdateSourceTrigger=PropertyChanged}"/>

        <components:TextInput
            Width="400"
            Height="40"
            Margin="0,0,0,15"
            Placeholder="Path to archive"
            LeftIcon="/ONYX Archiver;component/UI/Resources/Icons/ToolbarButtons/archive.png"
            Text="{Binding ArchivePath, UpdateSourceTrigger=PropertyChanged}"
            Command="{Binding GetArchivePathCommand}"/>

        <components:TextInput
            Width="400"
            Height="40"
            Margin="0,0,0,15"
            Placeholder="Recipient"
            LeftIcon="/ONYX Archiver;component/UI/Resources/Icons/PeersItems/user_key.png"
            Text="{Binding SelectedPeerName, UpdateSourceTrigger=PropertyChanged}"
            Command="{Binding OpenPeersListDialogCommand}"/>

        <components:SolidButton
            Width="400"
            Height="40"
            Margin="0,0,0,30"
            FontSize="14"
            Background="{StaticResource GreenButtonBrush}"
            CornerRadius="8"
            Text="Confirm configuration and archive"
            LeftIcon="/ONYX Archiver;component/UI/Resources/Icons/AuthForms/login.png"
            IconColor="#FFFFFF"
            Command="{Binding ConfirmArchiveCommand}"/>

        <TextBlock
            Text="{Binding Error}"
            Foreground="{StaticResource ErrorMessageBrush}"
            FontSize="14"
            HorizontalAlignment="Center"/>
    </StackPanel>
</Window>
