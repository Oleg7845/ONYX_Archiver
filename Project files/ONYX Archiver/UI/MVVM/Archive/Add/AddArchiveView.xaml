<UserControl x:Class="OnyxArchiver.UI.MVVM.Archive.Add.AddArchiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OnyxArchiver.UI.MVVM.Archive.Add"
             xmlns:components="clr-namespace:OnyxArchiver.UI.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Border
            BorderBrush="{StaticResource MainTextBrush}"
            BorderThickness="2"
            CornerRadius="10" 
            Background="{StaticResource BlackBrush}"
            Margin="50"
            AllowDrop="True"
            Drop="DropArea_Drop"
            DragOver="DropArea_DragOver">

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <Image
                    Height="180"
                    Width="180"
                    Source="/ONYX Archiver;component/UI/Resources/Icons/ToolbarButtons/plus.png"
                    Stretch="Uniform"
                    RenderOptions.BitmapScalingMode="HighQuality"/>

                <TextBlock
                    Text="Drag and drop file or folder here" 
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,15,0,0"
                    FontSize="16"
                    Foreground="{StaticResource MainTextBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
