<UserControl x:Class="OnyxArchiver.UI.MVVM.Auth.Login.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OnyxArchiver.UI.MVVM.Auth.Login"
             xmlns:components="clr-namespace:OnyxArchiver.UI.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border
        Background="{StaticResource BlackBrush}"
        BorderBrush="{StaticResource PanelBorderBrush}" 
        BorderThickness="1" 
        CornerRadius="8"
        VerticalAlignment="Center"
        HorizontalAlignment="Center"
        Padding="0, 20"
        Width="400"
        Height="380">
        <StackPanel
            Orientation="Vertical"
            HorizontalAlignment="Center">
            
            <TextBlock
                Text="Authentication"
                Foreground="{StaticResource MainTextBrush}"
                FontSize="20"
                FontWeight="Medium"
                Margin="0,10,0,25"
                HorizontalAlignment="Center"/>
            
            <components:TextInput
                Width="300"
                Height="40"
                Margin="0,0,0,15"
                Placeholder="Username"
                LeftIcon="/ONYX Archiver;component/UI/Resources/Icons/AuthForms/user.png"
                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

            <components:TextInput
                Width="300"
                Height="40"
                Margin="0,0,0,15"
                Placeholder="Password"
                IsPasswordMode="True"
                LeftIcon="/ONYX Archiver;component/UI/Resources/Icons/AuthForms/padlock.png"
                Text="{Binding Password}"/>

            <components:SolidButton
                Width="300"
                Height="40"
                Margin="0,0,0,30"
                FontSize="14"
                Background="{StaticResource GreenButtonBrush}"
                CornerRadius="8"
                Text="Log in"
                LeftIcon="/ONYX Archiver;component/UI/Resources/Icons/AuthForms/login.png"
                IconColor="#FFFFFF"
                Command="{Binding LoginCommand}"/>

            <components:SolidButton
                Height="16"
                Padding="0,0,0,2"
                HorizontalAlignment="Center"
                Margin="0,0,0,25"
                FontSize="14"
                Background="Transparent"
                Foreground="{StaticResource MainTextBrush}"
                Text="Create a new account"
                RightIcon="/ONYX Archiver;component/UI/Resources/Icons/AuthForms/arrow_forward.png"
                Command="{Binding GoToRegistrationCommand}"/>

            <TextBlock
                Text="{Binding Error}"
                Foreground="{StaticResource ErrorMessageBrush}"
                FontSize="14"
                HorizontalAlignment="Center"/>
            
        </StackPanel>
    </Border>
</UserControl>
