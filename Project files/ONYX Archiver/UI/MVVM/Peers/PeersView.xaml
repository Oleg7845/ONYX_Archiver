<UserControl x:Class="OnyxArchiver.UI.MVVM.Peers.PeersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OnyxArchiver.UI.MVVM.Peers"
             xmlns:components="clr-namespace:OnyxArchiver.UI.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Background="{StaticResource BlackBrush}"
            Padding="10"
            BorderBrush="#333333"
            BorderThickness="0,1,0,1">

            <StackPanel
                Orientation="Horizontal">

                <components:SolidButton
                    Width="40"
                    Height="40"
                    Padding="8,0,0,0"
                    FontSize="14"
                    Background="{StaticResource GreenButtonBrush}"
                    CornerRadius="8"
                    Text=""
                    ToolTip="Begin handshake"
                    LeftIcon="/ONYX Archiver;component/UI/Resources/Icons/ToolbarButtons/plus.png"
                    IconColor="#FFFFFF"
                    Command="{Binding OpenCreationPeerDialogCommand}"/>

                <components:SolidButton
                    Width="40"
                    Height="40"
                    Margin="15,0"
                    Padding="8,0,0,0"
                    FontSize="14"
                    Background="{StaticResource GreenButtonBrush}"
                    CornerRadius="8"
                    Text=""
                    ToolTip="Accept handshake"
                    LeftIcon="/ONYX Archiver;component/UI/Resources/Icons/ToolbarButtons/checkmark.png"
                    IconColor="#FFFFFF"
                    Command="{Binding AcceptHandshakeCommand}"/>

                <components:SolidButton
                    Width="40"
                    Height="40"
                    Padding="8,0,0,0"
                    FontSize="14"
                    Background="{StaticResource GreenButtonBrush}"
                    CornerRadius="8"
                    Text=""
                    ToolTip="Finalize handshake"
                    LeftIcon="/ONYX Archiver;component/UI/Resources/Icons/ToolbarButtons/link.png"
                    IconColor="#FFFFFF"
                    Command="{Binding FinalizeHandshakeCommand}"/>
            </StackPanel>
        </Border>

        <DataGrid
            Grid.Row="1"
            ItemsSource="{Binding Peers}"
            GridLinesVisibility="All" 
            HorizontalGridLinesBrush="#333333" 
            VerticalGridLinesBrush="#333333"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            RowHeight="36"
            Background="Transparent"
            BorderThickness="0"
            HeadersVisibility="Column"
            AlternationCount="2" 
            RowBackground="{StaticResource BlackBrush}" 
            AlternatingRowBackground="{StaticResource GrayBrush}"
            ScrollViewer.ScrollChanged="PeersGrid_ScrollChanged">

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="ID" MinWidth="280" MaxWidth="330" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">

                                <Border Width="20" Height="20" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}" Margin="0,0,8,0">
                                    <Border.OpacityMask>
                                        <ImageBrush
                                            ImageSource="/ONYX Archiver;component/UI/Resources/Icons/PeersItems/user_key.png"
                                            Stretch="Uniform"
                                            RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border.OpacityMask>
                                </Border>

                                <TextBlock
                                    Text="{Binding PeerId}"
                                    VerticalAlignment="Center"
                                    Padding="0,0,0,2"
                                    FontSize="14"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0"/>
                            <Setter Property="Padding" Value="0,0,0,2"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Header="Created At"
                    Binding="{Binding CreatedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}"
                    Width="130"
                    IsReadOnly="True">

                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0"/>
                            <Setter Property="Padding" Value="0,0,0,2"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>


                <DataGridTextColumn
                    Header="Finalized At"
                    Binding="{Binding FinalizedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}"
                    Width="130"
                    IsReadOnly="True">

                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0"/>
                            <Setter Property="Padding" Value="0,0,0,2"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn
                    Header="Actions"
                    Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                <Button
                                    Height="26"
                                    ToolTip="Edit"
                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconButtonGridStyle}">
                                    <Border Width="16" Height="16" Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}">
                                        <Border.OpacityMask>
                                            <ImageBrush
                                                ImageSource="/ONYX Archiver;component/UI/Resources/Icons/PeersItems/edit.png"
                                                Stretch="Uniform"
                                                RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border.OpacityMask>
                                    </Border>
                                </Button>

                                <Button
                                    Height="26"
                                    Margin="10,0,0,0"
                                    ToolTip="Delete"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconButtonGridStyle}">
                                    <Border Width="16" Height="16" Background="{StaticResource ErrorMessageBrush}">
                                        <Border.OpacityMask>
                                            <ImageBrush
                                                ImageSource="/ONYX Archiver;component/UI/Resources/Icons/PeersItems/trash.png"
                                                Stretch="Uniform"
                                                RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border.OpacityMask>
                                    </Border>
                                </Button>

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="{x:Type DataGridColumnHeader}">
                    <Setter Property="Background" Value="{StaticResource GrayBrush}"/>
                    <Setter Property="Foreground" Value="#808695"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#333333"/>

                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#252526"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Foreground" Value="{StaticResource MainTextBrush}"/>

                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#3F3F46"/>
                            <Setter Property="Foreground" Value="{StaticResource MainTextLightBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
        </DataGrid>
    </Grid>
</UserControl>
