<Window x:Class="OnyxArchiver.UI.MVVM.Peers.Dialogs.UpdatePeer.UpdatePeerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OnyxArchiver.UI.MVVM.Peers.Dialogs.UpdatePeer"
        xmlns:components="clr-namespace:OnyxArchiver.UI.Components"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Title="Update peer"
        Width="400"
        Height="270"
        Background="{StaticResource BlackBrush}">

    <StackPanel
        VerticalAlignment="Center"
        HorizontalAlignment="Center">

        <TextBlock
            Text="Update peer"
            Foreground="{StaticResource MainTextBrush}"
            FontSize="20"
            FontWeight="Medium"
            Margin="0,20,0,25"
            HorizontalAlignment="Center"/>

        <components:TextInput
            Width="300"
            Height="40"
            Margin="0,0,0,15"
            Placeholder="New name"
            LeftIcon="/ONYX Archiver;component/UI/Resources/Icons/PeersItems/user_key.png"
            Text="{Binding PeerName, UpdateSourceTrigger=PropertyChanged}"/>

        <components:SolidButton
            Width="300"
            Height="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,25"
            FontSize="14"
            Background="{StaticResource GreenButtonBrush}"
            CornerRadius="8"
            Text="Confirm"
            LeftIcon="/ONYX Archiver;component/UI/Resources/Icons/PeersItems/edit.png"
            IconColor="#FFFFFF"
            Command="{Binding ConfirmCommand}"/>

        <TextBlock
            Text="{Binding Error}"
            Foreground="{StaticResource ErrorMessageBrush}"
            FontSize="14"
            HorizontalAlignment="Center"
            Margin="0,0,0,40"/>
    </StackPanel>
</Window>
