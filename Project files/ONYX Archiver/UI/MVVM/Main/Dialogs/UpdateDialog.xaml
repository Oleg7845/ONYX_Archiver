<UserControl x:Class="OnyxArchiver.UI.MVVM.Main.Dialogs.UpdateDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OnyxArchiver.UI.MVVM.Main.Dialogs"
             xmlns:components="clr-namespace:OnyxArchiver.UI.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border
            Width="400"
            Height="150"
            Padding="20"
            CornerRadius="10"
            Background="{StaticResource GrayBrush}">

            <StackPanel>

                <TextBlock
                    Text="New version available"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{StaticResource MainTextBrush}"/>

                <TextBlock
                    Margin="0 10 0 20"
                    Text="Download update now?"
                    Foreground="{StaticResource MainTextBrush}"/>

                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

                    <components:SolidButton 
                        Text="Later"
                        Width="80"
                        Margin="0,0,15,0"
                        Padding="0,8"
                        CornerRadius="5"
                        Background="{StaticResource MainTextBrush}"
                        Foreground="#FFFFFF"
                        Click="LaterClick"/>

                    <components:SolidButton 
                        Text="Update"
                        Width="80"
                        Padding="0,8"
                        CornerRadius="5"
                        Background="{StaticResource GreenButtonBrush}"
                        Foreground="#FFFFFF"
                        Click="UpdateClick"/>

                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
