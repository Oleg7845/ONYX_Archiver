<UserControl x:Class="OnyxArchiver.UI.MVVM.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OnyxArchiver.UI.MVVM.Settings"
             xmlns:components="clr-namespace:OnyxArchiver.UI.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border
        Padding="20">
        <StackPanel>
            <TextBlock
                Text="Settings"
                FontSize="22"
                FontWeight="SemiBold"
                Foreground="{StaticResource MainTextBrush}"
                Margin="0,0,0,20"/>

            <components:SolidButton
                HorizontalAlignment="Left"
                Height="16"
                Padding="0,0,0,2"
                Margin="0,0,0,15"
                FontSize="16"
                Background="Transparent"
                Foreground="{StaticResource MainTextBrush}"
                Text="Change password"
                LeftIcon="/UI/Resources/Icons/ToolbarButtons/change_password.png"
                RightIcon="/ONYX Archiver;component/UI/Resources/Icons/AuthForms/arrow_forward.png"
                Command="{Binding OpenChangePasswordWindowCommand}"/>

            <components:SolidButton
                HorizontalAlignment="Left"
                Height="16"
                Padding="0,0,0,2"
                FontSize="16"
                Background="Transparent"
                Foreground="{StaticResource MainTextBrush}"
                Text="Delete account"
                LeftIcon="/UI/Resources/Icons/ToolbarButtons/user_delete.png"
                RightIcon="/ONYX Archiver;component/UI/Resources/Icons/AuthForms/arrow_forward.png"
                Command="{Binding OpenDeleteAccountWindowCommand}"/>
        </StackPanel>
    </Border>
</UserControl>
